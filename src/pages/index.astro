---
import { scriptLoadOrder } from '../data/script-load-order.js';
import { libraryProjectsBridge } from '../data/library-projects-bridge.js';
import { libraryBooks } from '../data/library-books.js';

const bookShowcaseClass = (book) => ['book-showcase', book.showcaseModifier].filter(Boolean).join(' ');
const bookCoverClass = (book) => ['book-cover', book.coverModifier].filter(Boolean).join(' ');
const bookSpineClass = (book) => ['book-spine', book.spineModifier].filter(Boolean).join(' ');
---

<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>葉桜ラボ — AIと、語ろう。自然と、遊ぼう。</title>
    <meta name="description" content="AIと、語ろう。自然と、遊ぼう。——変化を楽しむ研究所、葉桜ラボへようこそ。">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700;800&family=Noto+Serif+JP:wght@200;300;400;500;600;700;900&family=Noto+Sans+JP:wght@200;300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/style.css">

    <!-- SEO & SNS -->
    <meta property="og:title" content="葉桜ラボ — AIと、語ろう。自然と、遊ぼう。">
    <meta property="og:description" content="AIと、語ろう。自然と、遊ぼう。——変化を楽しむ研究所、葉桜ラボへようこそ。">
    <meta property="og:type" content="website">
    <meta property="og:image" content="./img/hero.png">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" type="image/png" href="./img/hero.png">
</head>

<body>
    <!-- スクロールプログレスバー -->
    <div class="scroll-progress" id="scroll-progress"></div>

    <!-- zone境界線 -->
    <div class="zone-border zone-border--dusk-night"></div>
    <div class="zone-border zone-border--night-moon"></div>

    <!-- カスタムカーソル -->
    <div class="custom-cursor" id="cursor-dot"></div>
    <div class="custom-cursor" id="cursor-ring"></div>

    <!-- 桜の花びらキャンバス -->
    <canvas id="sakura-canvas"></canvas>

    <!-- ナビゲーション -->
    <nav id="nav-main" class="nav">
        <div class="nav-inner">
            <a href="#hero" class="nav-logo" id="nav-logo">
                <span class="logo-icon">🌸</span>
                <span class="logo-text">葉桜ラボ</span>
            </a>
            <ul class="nav-links" id="nav-links">
                <li><a href="#philosophy">哲 学</a></li>
                <li><a href="#layers">構 造</a></li>
                <li><a href="#library">書 庫</a></li>
                <li><a href="#projects">制 作</a></li>
                <li><a href="#vision">構 想</a></li>
            </ul>
        </div>
    </nav>

    <!-- ヒーローセクション -->
    <section id="hero" class="hero" data-zone="day">
        <!-- メッシュグラデーション背景 -->
        <div class="hero-mesh">
            <div class="mesh-blob mesh-blob--1"></div>
            <div class="mesh-blob mesh-blob--2"></div>
            <div class="mesh-blob mesh-blob--3"></div>
            <div class="mesh-blob mesh-blob--4"></div>
        </div>
        <!-- 奥行きグラデーションレイヤー -->
        <div class="hero-depth-layer"></div>
        <div class="hero-overlay"></div>
        <div class="hero-image-container">
            <img src="./img/hero.png" alt="満開を過ぎた桜の木の下で、少女がAIの光と対話している葉桜ラボのメインビジュアル" class="hero-image" id="hero-image">
        </div>
        <div class="hero-content">
            <div class="hero-intro">
                <p class="hero-kana" id="hero-kana">はざくら・らぼ</p>
                <h1 class="hero-title" id="hero-title">
                    <span class="title-line title-line--1">AIと、語ろう。</span>
                    <span class="title-line title-line--2">自然と、遊ぼう。</span>
                </h1>
                <span class="title-accent-line title-line--3">—— 変化を楽しむ研究所</span>
            </div>
            <p class="hero-subtitle" id="hero-subtitle">
                満開の先にある、移ろいの美しさ。<br>
                理と情が習合する、循環する魔法の拠点。
            </p>
            <div class="hero-cta-group">
                <a href="#philosophy" class="hero-cta hero-cta--primary">
                    <span>探る</span>
                    <span class="cta-arrow">→</span>
                </a>
                <a href="#library" class="hero-cta hero-cta--secondary">
                    <span>書庫へ寄る</span>
                    <span class="cta-arrow">→</span>
                </a>
            </div>
        </div>
        <div class="hero-scroll-hint" id="hero-scroll-hint">
            <span class="scroll-text">scroll</span>
            <span class="scroll-line"></span>
        </div>
    </section>

    <!-- 哲学科セクション -->
    <section id="philosophy" class="section section-philosophy" data-zone="day">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Core Philosophy</span>
                <h2 class="section-title">三つの花弁</h2>
                <p class="section-desc">
                    葉桜ラボの根底に流れる、三つの思想。<br>
                    それは佐久間象山の歌に倣った、「移ろい」への讃歌です。
                </p>
            </div>
            <div class="philosophy-grid" id="philosophy-grid" data-render="philosophy">
            </div>
        </div>
    </section>

    <!-- リッチ化の構造セクション -->
    <section id="layers" class="section section-layers" data-zone="dusk">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">One-page Architecture</span>
                <h2 class="section-title">一枚の中に、層をつくる</h2>
                <p class="section-desc">
                    1ページのまま深くしていくために、思想・成果・演出・循環を<br>
                    それぞれ独立して育てられるレイヤーとして扱います。
                </p>
            </div>
            <div class="layer-grid" id="layer-grid" data-render="experienceLayers"></div>
        </div>
    </section>


    <!-- 書庫セクション -->
    <section id="library" class="section section-library" data-zone="dusk">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Library — 書庫</span>
                <h2 class="section-title">知恵の結晶</h2>
                <p class="section-desc">
                    哲学AI「チカちゃん」と、けい君が紡いだ二つの記録。<br>
                    売り場ではなく、問いが言葉へ結晶した小さな書庫です。
                </p>
            </div>
            <div class="book-shelf" aria-label="チカちゃんシリーズの書籍">
                {libraryBooks.map((book) => (
                    <div class={bookShowcaseClass(book)} id={book.showcaseId}>
                        <div class="book-visual">
                            <div class="book-3d" id={book.bookId}>
                                <div class={bookCoverClass(book)}>
                                    <img class="book-cover-art book-cover-art--clear" src={book.image.src}
                                        alt={book.image.alt}>
                                    <div class="book-glare"></div>
                                </div>
                                <div class={bookSpineClass(book)}></div>
                            </div>
                        </div>
                        <div class="book-info">
                            <div class="book-meta">
                                {book.meta.map((meta) => (
                                    <span class="meta-tag">{meta}</span>
                                ))}
                            </div>
                            <h3 class="book-info-title">{book.title}</h3>
                            <p class="book-info-subtitle">{book.subtitle}</p>
                            <p class="book-description">
                                {book.description.map((line, index) => (
                                    <>
                                        {line}
                                        {index < book.description.length - 1 && <br />}
                                    </>
                                ))}
                            </p>
                            <div class="book-highlights">
                                {book.highlights.map((highlight) => (
                                    <div class="highlight-item">
                                        <span class="highlight-icon">{highlight.icon}</span>
                                        <span class="highlight-text">{highlight.text}</span>
                                    </div>
                                ))}
                            </div>
                            <div class="book-price">
                                <span class="price-label">{book.price.label}</span>
                                <span class="price-value">{book.price.value}</span>
                                <span class="price-or">{book.price.connector}</span>
                                <span class="price-buy">{book.price.buy}</span>
                            </div>
                            <a href={book.action.href} target="_blank" rel="noopener noreferrer"
                                class="book-cta" id={book.action.id}>
                                <span class="cta-icon">{book.action.icon}</span>
                                <span class="cta-text">{book.action.label}</span>
                                <span class="cta-arrow">→</span>
                            </a>
                        </div>
                    </div>
                ))}
            </div>

            <div class="library-projects-bridge" aria-labelledby="library-projects-bridge-title">
                <span class="library-projects-bridge__thread" aria-hidden="true"></span>
                <div class="library-projects-bridge__copy">
                    <span class="library-projects-bridge__eyebrow">{libraryProjectsBridge.eyebrow}</span>
                    <h3 id="library-projects-bridge-title">{libraryProjectsBridge.title}</h3>
                    <p>{libraryProjectsBridge.text}</p>
                </div>
                <ol class="library-projects-bridge__steps" aria-label="書庫の問いを制作棚へ渡す流れ">
                    {libraryProjectsBridge.steps.map((step) => (
                        <li>
                            <span>{step.label}</span>
                            <p>{step.text}</p>
                        </li>
                    ))}
                </ol>
                <a href={libraryProjectsBridge.action.href} class="library-projects-bridge__link">
                    <span>{libraryProjectsBridge.action.label}</span>
                    <span aria-hidden="true">→</span>
                </a>
            </div>
        </div>
    </section>



    <!-- 作品・プロジェクト紹介セクション -->
    <section id="projects" class="section section-projects" data-zone="night">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Projects — 実験の棚</span>
                <h2 class="section-title">問いから生まれた実験</h2>
                <p class="section-desc">
                    書庫で結晶化した問いを、公開済みのツール、試作中の道具、まだ物語になる前の風景へ戻します。<br>
                    何をつくったかより、どの問いが次の実験へ巡ったかを眺めます。
                </p>
            </div>
            <div class="project-list" id="project-list" data-render="projects">
            </div>
        </div>
    </section>

    <!-- 構想セクション -->
    <section id="vision" class="section section-vision" data-zone="moon">
        <!-- 星空 -->
        <div class="star-layer star-layer--large"></div>
        <div class="star-layer star-layer--medium"></div>
        <div class="star-layer star-layer--small"></div>
        <!-- 夜の月（絶対配置） -->
        <div class="night-moon">
            <div class="moon-body"></div>
        </div>

        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Vision — 構想</span>
                <h2 class="section-title">次に育つ問い</h2>
                <p class="section-desc">
                    未来の地図を描き切る前に、問い、記憶、道具、知恵をどこへ預けるかを見る。<br>
                    ここでは構想を、次の実験へ渡す入口として眺めます。
                </p>
            </div>
            <div class="vision-grid" id="vision-grid" data-render="visions">
            </div>
            <!-- プロセスフロー -->
            <div class="process-flow process-flow--vision" id="process-flow" data-render="process"
                aria-label="預けた入口が研究ログへ巡る流れ">
            </div>
            <div class="research-log-strip" id="research-log-strip" data-render="researchLogs">
            </div>
            <div class="cycle-bridge" id="cycle-bridge" data-render="cycleBridge">
            </div>
        </div>
    </section>

    <!-- 引用セクション -->
    <section id="quote" class="section section-quote" data-zone="aurora">
        <div class="section-inner">
            <div class="quote-prelude" id="quote-prelude" data-render="quotePrelude"></div>
            <blockquote class="quote-block" id="quote-block">
                <p class="quote-text">
                    時にあわば<br>散るもめでたし 桜花<br>
                    めずるは花の 盛りのみかは
                </p>
                <cite class="quote-cite">— 佐久間象山</cite>
            </blockquote>
            <p class="quote-commentary">
                すべては移ろう。だからこそ、今この瞬間の探求に意味がある。
            </p>
        </div>
    </section>



    <!-- フッター -->
    <footer class="footer" id="footer">
        <div class="footer-inner">
            <div class="footer-content">
                <div class="footer-logo">
                    <span class="logo-icon">🌸</span>
                    <span class="logo-text">葉桜ラボ</span>
                </div>
                <p class="footer-philosophy">
                    AIの知性と、自然の情緒が溶け合う「循環する魔法の拠点」
                </p>
                <div class="footer-garden-close" aria-label="葉桜ラボの庭をもう一度巡る小径">
                    <span class="footer-garden-close__seed" aria-hidden="true">✧</span>
                    <p>読み終えた問いを、もう一度だけ庭へ戻す。</p>
                    <a href="#hero" class="footer-garden-close__link">
                        <span>はじまりへ戻る</span>
                        <span aria-hidden="true">↑</span>
                    </a>
                </div>
                <div class="footer-nav">
                    <a href="#philosophy">哲学</a>
                    <a href="#layers">構造</a>
                    <a href="#library">書庫</a>
                    <a href="#projects">制作</a>
                    <a href="#vision">構想</a>
                </div>
                <div class="footer-links">
                    <a href="https://www.amazon.co.jp/dp/B0GSWNNZL7" target="_blank"
                        rel="noopener noreferrer">Kindleで読む</a>
                    <!-- <a href="https://github.com/hazakuralabo" target="_blank" rel="noopener noreferrer">GitHub</a> -->
                </div>
            </div>
            <div class="footer-bottom">
                <p class="footer-copy">&copy; 2026 葉桜ラボ / Hazakura Lab</p>
            </div>
        </div>
    </footer>

    {scriptLoadOrder.map((scriptSrc) => <script is:inline src={scriptSrc}></script>)}
</body>

</html>
