---
import HeroSection from '../components/HeroSection.astro';
import FoundationSections from '../components/FoundationSections.astro';
import LibrarySection from '../components/LibrarySection.astro';
import FooterSection from '../components/FooterSection.astro';
import MainNavigation from '../components/MainNavigation.astro';
import QuoteSection from '../components/QuoteSection.astro';
import { scriptLoadOrder } from '../data/script-load-order.js';
import { siteMeta, siteSocialImageUrl } from '../data/site-meta.js';
---

<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{siteMeta.title}</title>
    <meta name="description" content={siteMeta.description}>
    <link rel="canonical" href={siteMeta.siteUrl}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700;800&family=Noto+Serif+JP:wght@200;300;400;500;600;700;900&family=Noto+Sans+JP:wght@200;300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/style.css">

    <!-- SEO & SNS -->
    <meta property="og:title" content={siteMeta.title}>
    <meta property="og:description" content={siteMeta.description}>
    <meta property="og:type" content={siteMeta.ogType}>
    <meta property="og:url" content={siteMeta.siteUrl}>
    <meta property="og:image" content={siteSocialImageUrl}>
    <meta property="og:image:alt" content={siteMeta.imageAlt}>
    <meta name="twitter:card" content={siteMeta.twitterCard}>
    <meta name="twitter:title" content={siteMeta.title}>
    <meta name="twitter:description" content={siteMeta.description}>
    <meta name="twitter:image" content={siteSocialImageUrl}>
    <link rel="icon" type="image/png" href={siteMeta.imagePath}>
</head>

<body>
    <!-- スクロールプログレスバー -->
    <div class="scroll-progress" id="scroll-progress"></div>

    <!-- zone境界線 -->
    <div class="zone-border zone-border--dusk-night"></div>
    <div class="zone-border zone-border--night-moon"></div>

    <!-- カスタムカーソル -->
    <div class="custom-cursor" id="cursor-dot"></div>
    <div class="custom-cursor" id="cursor-ring"></div>

    <!-- 桜の花びらキャンバス -->
    <canvas id="sakura-canvas"></canvas>

    <MainNavigation />

    <HeroSection />

    <FoundationSections />

    <LibrarySection />

    <!-- 作品・プロジェクト紹介セクション -->
    <section id="projects" class="section section-projects" data-zone="night">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Projects — 実験の棚</span>
                <h2 class="section-title">問いから生まれた実験</h2>
                <p class="section-desc">
                    書庫で結晶化した問いを、公開済みのツール、試作中の道具、まだ物語になる前の風景へ戻します。<br>
                    何をつくったかより、どの問いが次の実験へ巡ったかを眺めます。
                </p>
            </div>
            <div class="project-list" id="project-list" data-render="projects">
            </div>
        </div>
    </section>

    <!-- 構想セクション -->
    <section id="vision" class="section section-vision" data-zone="moon">
        <!-- 星空 -->
        <div class="star-layer star-layer--large"></div>
        <div class="star-layer star-layer--medium"></div>
        <div class="star-layer star-layer--small"></div>
        <!-- 夜の月（絶対配置） -->
        <div class="night-moon">
            <div class="moon-body"></div>
        </div>

        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Vision — 構想</span>
                <h2 class="section-title">次に育つ問い</h2>
                <p class="section-desc">
                    未来の地図を描き切る前に、問い、記憶、道具、知恵をどこへ預けるかを見る。<br>
                    ここでは構想を、次の実験へ渡す入口として眺めます。
                </p>
            </div>
            <div class="vision-grid" id="vision-grid" data-render="visions">
            </div>
            <!-- プロセスフロー -->
            <div class="process-flow process-flow--vision" id="process-flow" data-render="process"
                aria-label="預けた入口が研究ログへ巡る流れ">
            </div>
            <section class="research-log-strip" id="research-log-strip" data-render="researchLogs"
                aria-labelledby="research-log-strip-title">
            </section>
            <div class="cycle-bridge" id="cycle-bridge" data-render="cycleBridge">
            </div>
        </div>
    </section>

    <QuoteSection />

    <FooterSection />

    {scriptLoadOrder.map((scriptSrc) => <script is:inline src={scriptSrc}></script>)}
</body>

</html>
