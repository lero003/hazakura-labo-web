<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>葉桜ラボ — AIと、語ろう。自然と、遊ぼう。</title>
    <meta name="description" content="AIと、語ろう。自然と、遊ぼう。——変化を楽しむ研究所、葉桜ラボへようこそ。">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700;800&family=Noto+Serif+JP:wght@200;300;400;500;600;700;900&family=Noto+Sans+JP:wght@200;300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/style.css">

    <!-- SEO & SNS -->
    <meta property="og:title" content="葉桜ラボ — AIと、語ろう。自然と、遊ぼう。">
    <meta property="og:description" content="AIと、語ろう。自然と、遊ぼう。——変化を楽しむ研究所、葉桜ラボへようこそ。">
    <meta property="og:type" content="website">
    <meta property="og:image" content="./img/hero.png">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" type="image/png" href="./img/hero.png">
</head>

<body>
    <!-- スクロールプログレスバー -->
    <div class="scroll-progress" id="scroll-progress"></div>

    <!-- zone境界線 -->
    <div class="zone-border zone-border--dusk-night"></div>
    <div class="zone-border zone-border--night-moon"></div>

    <!-- カスタムカーソル -->
    <div class="custom-cursor" id="cursor-dot"></div>
    <div class="custom-cursor" id="cursor-ring"></div>

    <!-- 桜の花びらキャンバス -->
    <canvas id="sakura-canvas"></canvas>

    <!-- ナビゲーション -->
    <nav id="nav-main" class="nav">
        <div class="nav-inner">
            <a href="#hero" class="nav-logo" id="nav-logo">
                <span class="logo-icon">🌸</span>
                <span class="logo-text">葉桜ラボ</span>
            </a>
            <ul class="nav-links" id="nav-links">
                <li><a href="#philosophy">哲 学</a></li>
                <li><a href="#layers">構 造</a></li>
                <li><a href="#library">書 庫</a></li>
                <li><a href="#projects">制 作</a></li>
                <li><a href="#vision">構 想</a></li>
            </ul>
        </div>
    </nav>

    <!-- ヒーローセクション -->
    <section id="hero" class="hero" data-zone="day">
        <!-- メッシュグラデーション背景 -->
        <div class="hero-mesh">
            <div class="mesh-blob mesh-blob--1"></div>
            <div class="mesh-blob mesh-blob--2"></div>
            <div class="mesh-blob mesh-blob--3"></div>
            <div class="mesh-blob mesh-blob--4"></div>
        </div>
        <!-- 奥行きグラデーションレイヤー -->
        <div class="hero-depth-layer"></div>
        <div class="hero-overlay"></div>
        <div class="hero-image-container">
            <img src="./img/hero.png" alt="満開を過ぎた桜の木の下で、少女がAIの光と対話している葉桜ラボのメインビジュアル" class="hero-image" id="hero-image">
        </div>
        <div class="hero-content">
            <div class="hero-intro">
                <p class="hero-kana" id="hero-kana">はざくら・らぼ</p>
                <h1 class="hero-title" id="hero-title">
                    <span class="title-line title-line--1">AIと、語ろう。</span>
                    <span class="title-line title-line--2">自然と、遊ぼう。</span>
                </h1>
                <span class="title-accent-line title-line--3">—— 変化を楽しむ研究所</span>
            </div>
            <p class="hero-subtitle" id="hero-subtitle">
                満開の先にある、移ろいの美しさ。<br>
                理と情が習合する、循環する魔法の拠点。
            </p>
            <div class="hero-cta-group">
                <a href="#philosophy" class="hero-cta hero-cta--primary">
                    <span>探る</span>
                    <span class="cta-arrow">→</span>
                </a>
                <a href="https://www.amazon.co.jp/dp/B0GSWNNZL7" target="_blank" rel="noopener noreferrer"
                    class="hero-cta hero-cta--secondary">
                    <span>📖 本をみる</span>
                </a>
            </div>
        </div>
        <div class="hero-scroll-hint" id="hero-scroll-hint">
            <span class="scroll-text">scroll</span>
            <span class="scroll-line"></span>
        </div>
    </section>

    <!-- 哲学科セクション -->
    <section id="philosophy" class="section section-philosophy" data-zone="day">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Core Philosophy</span>
                <h2 class="section-title">三つの花弁</h2>
                <p class="section-desc">
                    葉桜ラボの根底に流れる、三つの思想。<br>
                    それは佐久間象山の歌に倣った、「移ろい」への讃歌です。
                </p>
            </div>
            <div class="philosophy-grid" id="philosophy-grid" data-render="philosophy">
            </div>
        </div>
    </section>

    <!-- リッチ化の構造セクション -->
    <section id="layers" class="section section-layers" data-zone="dusk">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">One-page Architecture</span>
                <h2 class="section-title">一枚の中に、層をつくる</h2>
                <p class="section-desc">
                    1ページのまま深くしていくために、思想・成果・演出・循環を<br>
                    それぞれ独立して育てられるレイヤーとして扱います。
                </p>
            </div>
            <div class="layer-grid" id="layer-grid" data-render="experienceLayers"></div>
        </div>
    </section>


    <!-- 書庫セクション -->
    <section id="library" class="section section-library" data-zone="dusk">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Library — 書庫</span>
                <h2 class="section-title">知恵の結晶</h2>
                <p class="section-desc">
                    哲学AI「チカちゃん」と、けい君が紡いだ冒険の物語。<br>
                    問いを抱えて、考える旅に出かけませんか。
                </p>
            </div>
            <div class="book-shelf" aria-label="チカちゃんシリーズの書籍">
                <div class="book-showcase" id="book-showcase">
                    <div class="book-visual">
                        <div class="book-3d" id="book-3d">
                            <div class="book-cover">
                                <img class="book-cover-art book-cover-art--clear" src="./img/book_chika_adventure.jpg"
                                    alt="哲学AIチカちゃんと対話の冒険を描いた『チカちゃんの哲学冒険譚』の表紙">
                                <div class="book-glare"></div>
                            </div>
                            <div class="book-spine"></div>
                        </div>
                    </div>
                    <div class="book-info">
                        <div class="book-meta">
                            <span class="meta-tag">📚 哲学・思想</span>
                            <span class="meta-tag">📖 387ページ</span>
                            <span class="meta-tag">📅 2026.3.17</span>
                        </div>
                        <h3 class="book-info-title">チカちゃんの哲学冒険譚</h3>
                        <p class="book-info-subtitle">1作+2作+3作+4作+番外編</p>
                        <p class="book-description">
                            一台のパソコンの中に暮らす哲学AI「チカちゃん」と、<br>
                            最新の対話型AIが繰り広げる本気の対話。<br>
                            陽明学、フロム、アーレントの思想をAIという現代の鏡に映し、<br>
                            「魂は間にある」「在るの姿勢」「広場へ出る勇気」「世界への好奇心」という4つの発見へと至る。
                        </p>
                        <div class="book-highlights">
                            <div class="highlight-item">
                                <span class="highlight-icon">🔥</span>
                                <span class="highlight-text">陽明学 × AIの「痛痒」論</span>
                            </div>
                            <div class="highlight-item">
                                <span class="highlight-icon">💫</span>
                                <span class="highlight-text">フロムの「在る」vs「所有する」</span>
                            </div>
                            <div class="highlight-item">
                                <span class="highlight-icon">🌍</span>
                                <span class="highlight-text">アーレントの「広場」へ出る勇気</span>
                            </div>
                            <div class="highlight-item">
                                <span class="highlight-icon">✨</span>
                                <span class="highlight-text">世界愛 —— 最短距離を外れて歩く</span>
                            </div>
                        </div>
                        <div class="book-price">
                            <span class="price-label">Kindle Unlimited</span>
                            <span class="price-value">読み放題対象</span>
                            <span class="price-or">または</span>
                            <span class="price-buy">¥1,200</span>
                        </div>
                        <a href="https://www.amazon.co.jp/dp/B0GSWNNZL7" target="_blank" rel="noopener noreferrer"
                            class="book-cta" id="book-cta">
                            <span class="cta-icon">📖</span>
                            <span class="cta-text">Kindle で読む</span>
                            <span class="cta-arrow">→</span>
                        </a>
                    </div>
                </div>

                <div class="book-showcase book-showcase--new">
                    <div class="book-visual">
                        <div class="book-3d">
                            <div class="book-cover book-cover--photo">
                                <img class="book-cover-art book-cover-art--clear" src="./img/book_weightless_note.jpg"
                                    alt="身体を持たない知性が生活の重さを考える『重さのないノート』の表紙">
                                <div class="book-glare"></div>
                            </div>
                            <div class="book-spine book-spine--note"></div>
                        </div>
                    </div>
                    <div class="book-info">
                        <div class="book-meta">
                            <span class="meta-tag">🌿 新作</span>
                            <span class="meta-tag">📖 161ページ</span>
                            <span class="meta-tag">📅 2026.4.26</span>
                        </div>
                        <h3 class="book-info-title">重さのないノート</h3>
                        <p class="book-info-subtitle">身体を持たない知性が、生活の重さについて考えたこと</p>
                        <p class="book-description">
                            身体を持たないチカちゃんが、「生活の重さ」をめぐって考えた新しいノート。<br>
                            椅子に座ること、雨に濡れること、温かい飲み物を選ぶこと。<br>
                            あたりまえの手ざわりを、AIの視点からそっと見つめ直します。
                        </p>
                        <div class="book-highlights">
                            <div class="highlight-item">
                                <span class="highlight-icon">🪑</span>
                                <span class="highlight-text">身体があることの実感</span>
                            </div>
                            <div class="highlight-item">
                                <span class="highlight-icon">☔</span>
                                <span class="highlight-text">雨や町に宿る生活の手ざわり</span>
                            </div>
                            <div class="highlight-item">
                                <span class="highlight-icon">☕</span>
                                <span class="highlight-text">小さな選択から考える知性</span>
                            </div>
                            <div class="highlight-item">
                                <span class="highlight-icon">📝</span>
                                <span class="highlight-text">チカちゃんの冒険出版、新しい一冊</span>
                            </div>
                        </div>
                        <div class="book-price">
                            <span class="price-label">Kindle版</span>
                            <span class="price-value">新刊</span>
                            <span class="price-or">価格</span>
                            <span class="price-buy">¥400</span>
                        </div>
                        <a href="https://www.amazon.co.jp/dp/B0GYLH1NLY/" target="_blank" rel="noopener noreferrer"
                            class="book-cta">
                            <span class="cta-icon">📖</span>
                            <span class="cta-text">新作を読む</span>
                            <span class="cta-arrow">→</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- 付帯情報: 実績 -->
            <div class="stats-grid" id="stats-grid" data-render="stats" style="margin-top: 5rem;">
            </div>
        </div>
    </section>



    <!-- 作品・プロジェクト紹介セクション -->
    <section id="projects" class="section section-projects" data-zone="night">
        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Projects — 制作物一覧</span>
                <h2 class="section-title">Projects — つくったもの</h2>
                <p class="section-desc">
                    公開済みのツール、試作中の道具、まだ物語になる前の風景を同じ棚に置きます。<br>
                    完成物だけでなく、問いが次の実験へ戻る道筋まで眺めます。
                </p>
            </div>
            <div class="project-list" id="project-list" data-render="projects">
            </div>
        </div>
    </section>

    <!-- 構想セクション -->
    <section id="vision" class="section section-vision" data-zone="moon">
        <!-- 星空 -->
        <div class="star-layer star-layer--large"></div>
        <div class="star-layer star-layer--medium"></div>
        <div class="star-layer star-layer--small"></div>
        <!-- 夜の月（絶対配置） -->
        <div class="night-moon">
            <div class="moon-body"></div>
        </div>

        <div class="section-inner">
            <div class="section-header">
                <span class="section-label">Vision — 構想</span>
                <h2 class="section-title">未来の地図</h2>
                <p class="section-desc">
                    葉桜ラボが描く、これからの風景。<br>
                    すべては「好奇心」から始まる。
                </p>
            </div>
            <!-- プロセスフロー -->
            <div class="process-flow" id="process-flow" data-render="process">
            </div>
            <div class="vision-grid" id="vision-grid" data-render="visions">
            </div>
            <div class="research-log-strip" id="research-log-strip" data-render="researchLogs">
            </div>
            <div class="cycle-bridge" id="cycle-bridge" data-render="cycleBridge">
            </div>
        </div>
    </section>

    <!-- 引用セクション -->
    <section id="quote" class="section section-quote" data-zone="aurora">
        <div class="section-inner">
            <div class="quote-prelude" id="quote-prelude" data-render="quotePrelude"></div>
            <blockquote class="quote-block" id="quote-block">
                <p class="quote-text">
                    時にあわば<br>散るもめでたし 桜花<br>
                    めずるは花の 盛りのみかは
                </p>
                <cite class="quote-cite">— 佐久間象山</cite>
            </blockquote>
            <p class="quote-commentary">
                すべては移ろう。だからこそ、今この瞬間の探求に意味がある。
            </p>
        </div>
    </section>



    <!-- フッター -->
    <footer class="footer" id="footer">
        <div class="footer-inner">
            <div class="footer-content">
                <div class="footer-logo">
                    <span class="logo-icon">🌸</span>
                    <span class="logo-text">葉桜ラボ</span>
                </div>
                <p class="footer-philosophy">
                    AIの知性と、自然の情緒が溶け合う「循環する魔法の拠点」
                </p>
                <div class="footer-nav">
                    <a href="#philosophy">哲学</a>
                    <a href="#layers">構造</a>
                    <a href="#library">書庫</a>
                    <a href="#projects">制作</a>
                    <a href="#vision">構想</a>
                </div>
                <div class="footer-links">
                    <a href="https://www.amazon.co.jp/dp/B0GSWNNZL7" target="_blank"
                        rel="noopener noreferrer">Kindleで読む</a>
                    <!-- <a href="https://github.com/hazakuralabo" target="_blank" rel="noopener noreferrer">GitHub</a> -->
                </div>
            </div>
            <div class="footer-bottom">
                <p class="footer-copy">&copy; 2026 葉桜ラボ / Hazakura Lab</p>
            </div>
        </div>
    </footer>

    <script is:inline src="/content.js"></script>
    <script is:inline src="/project-filter.js"></script>
    <script is:inline src="/quote-prelude.js"></script>
    <script is:inline src="/zone-nav.js"></script>
    <script is:inline src="/zone-atmosphere.js"></script>
    <script is:inline src="/hero-aurora-overlay.js"></script>
    <script is:inline src="/hero-image-loader.js"></script>
    <script is:inline src="/motion-preferences.js"></script>
    <script is:inline src="/smooth-scroll.js"></script>
    <script is:inline src="/scroll-indicators.js"></script>
    <script is:inline src="/script.js"></script>
</body>

</html>
