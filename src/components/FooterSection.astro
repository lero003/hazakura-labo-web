---
import LogoMark from './LogoMark.astro';

const navItems = [
  { href: '/', label: 'TOP' },
  { href: '/products', label: 'Product' },
  { href: '/notes', label: 'Notes' },
];
---

<footer class="footer" id="footer">
    <div class="footer-inner">
        <div class="footer-content">
            <div class="footer-logo">
                <LogoMark />
                <span class="logo-text">葉桜ラボ</span>
            </div>
            <p class="footer-philosophy">
                AIと自然、思想と制作が循環する小さな実験庭園
            </p>
            <nav class="footer-nav" aria-label="葉桜ラボの終端巡回路">
                {navItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                ))}
            </nav>
        </div>
        <div class="footer-bottom">
            <p class="footer-copy">&copy; 2026 葉桜ラボ / Hazakura Lab</p>
        </div>
    </div>
</footer>
