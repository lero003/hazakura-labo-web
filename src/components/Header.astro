---
import LogoMark from './LogoMark.astro';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'TOP' },
  { href: '/products', label: 'Product' },
  { href: '/notes', label: 'Notes' },
];
---

<nav id="nav-main" class="nav" aria-label="葉桜ラボの主要巡回路">
    <div class="nav-inner">
        <a href="/" class="nav-logo" id="nav-logo">
            <LogoMark />
            <span class="logo-text">葉桜ラボ</span>
        </a>
        <button class="nav-hamburger" id="nav-hamburger" aria-label="メニューを開く" aria-expanded="false" aria-controls="nav-links">
            <span class="nav-hamburger__line"></span>
            <span class="nav-hamburger__line"></span>
            <span class="nav-hamburger__line"></span>
        </button>
        <ul class="nav-links" id="nav-links">
            {navItems.map((item) => (
                <li>
                    <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
                        {item.label}
                    </a>
                </li>
            ))}
        </ul>
    </div>
</nav>

<script is:inline>
(function () {
    var btn = document.getElementById('nav-hamburger');
    var links = document.getElementById('nav-links');
    if (!btn || !links) return;
    btn.addEventListener('click', function () {
        var open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        btn.setAttribute('aria-label', open ? 'メニューを開く' : 'メニューを閉じる');
        links.classList.toggle('nav-links--open', !open);
    });
    links.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () {
            btn.setAttribute('aria-expanded', 'false');
            btn.setAttribute('aria-label', 'メニューを開く');
            links.classList.remove('nav-links--open');
        });
    });
})();
</script>
